# Miron AI Backend — Environment Variables
# Copy this file to .env and fill in the values
# Set these in Render / deployment dashboard for production

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:6543/<db>?sslmode=require

# Supabase (project: ffvdyjvmwmbtxqvqwhtt)
SUPABASE_URL=https://ffvdyjvmwmbtxqvqwhtt.supabase.co
SUPABASE_KEY=<supabase-anon-key>

# LLM provider
# Lenovo backend icin:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:1.5b-instruct
#
# Render fallback icin Groq veya OpenAI kullan:
# GROQ_API_KEY=gsk_...
# veya
OPENAI_API_KEY=sk-...

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=<admin-secret-key-32-chars>
JWT_SECRET=<jwt-secret-32-chars>
DATA_ENCRYPTION_KEY=<fernet-key-base64>
DATA_HASH_KEY=<hash-key-32-chars>

# Config
ENVIRONMENT=production
# Admin panel unlock password (set a strong random string)
ADMIN_PANEL_PASSWORD=<strong-random-password-here>
COOKIE_SECURE=1
FRONTEND_ORIGINS=https://miron22.vercel.app,http://localhost:5173
DB_STATEMENT_TIMEOUT=30000
DB_LOCK_TIMEOUT=30000
DB_POOL_TIMEOUT=30.0
