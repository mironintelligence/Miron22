{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 30 }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/main.py"
    }
  ],
  "regions": ["fra1"],
  "functions": {
    "backend/main.py": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
