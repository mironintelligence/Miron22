# Copy to .env.local for local dev
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_URL=http://127.0.0.1:8000
# Dokümantasyon: backend ADMIN_PANEL_PASSWORD ile aynı olmalı (doğrulama sunucuda).
VITE_ADMIN_PASSWORD=
# Supabase Auth (PKCE); access_token Bearer olarak Render API’ye gider — backend’de SUPABASE_JWT_SECRET gerekir
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
